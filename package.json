{
  "name": "zettel-compress",
  "version": "0.2.1",
  "description": "Deterministic LLM-free text compression into structured zettel memory units with emotion weights, entity codes, and tunnel links",
  "keywords": [
    "llm",
    "context-compression",
    "memory",
    "zettelkasten",
    "conversation-history",
    "token-reduction",
    "nlp",
    "langchain",
    "ai-sdk",
    "edge-compatible",
    "zettel",
    "aaak"
  ],
  "author": {
    "name": "shariq",
    "email": "shariqali0199@gmail.com",
    "url": "https://github.com/shariqaliq"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shariqaliq/zettel-compress.git"
  },
  "homepage": "https://github.com/shariqaliq/zettel-compress#readme",
  "bugs": {
    "url": "https://github.com/shariqaliq/zettel-compress/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "bench": "node bench/fetch-data.mjs && tsx bench/run.ts",
    "bench:llm": "tsx bench/qa-llm.ts",
    "check:zerodep": "node -e \"const d = require('./package.json').dependencies || {}; const k = Object.keys(d); if (k.length) { console.error('Zero-dependency check failed — runtime dependencies found: ' + k.join(', ')); process.exit(1) }\"",
    "prepublishOnly": "npm run check:zerodep && npm run build && npm run test && npm run typecheck",
    "bench:locomo": "tsx bench/locomo.ts",
    "build:playground": "esbuild src/index.ts --bundle --format=esm --minify --outfile=playground/zettel-compress.min.js"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^2.0.0",
    "node-summarizer": "^1.0.7",
    "tsup": "^8.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
